.section { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 20rpx; }
.stat-row { display: flex; flex-wrap: wrap; gap: 20rpx; }
.stat-item { flex: 1; min-width: 120rpx; text-align: center; }
.num { font-size: 36rpx; font-weight: bold; color: #409EFF; display: block; }
.lbl { font-size: 22rpx; color: #909399; display: block; }