.user-card { background: #fff; border-radius: 16rpx; padding: 40rpx; display: flex; align-items: center; gap: 30rpx; margin-bottom: 30rpx; }
.avatar { width: 100rpx; height: 100rpx; background: #409EFF; color: #fff; border-radius: 50%; text-align: center; line-height: 100rpx; font-size: 40rpx; }
.user-name { font-size: 32rpx; font-weight: bold; display: block; }
.user-role { font-size: 24rpx; color: #909399; display: block; margin-top: 10rpx; }
.menu-list { background: #fff; border-radius: 16rpx; }
.menu-item { padding: 30rpx; border-bottom: 1rpx solid #eee; font-size: 28rpx; }
.logout-btn { width: 100%; background: #f56c6c; color: #fff; border-radius: 12rpx; padding: 20rpx; text-align: center; margin-top: 40rpx; font-size: 28rpx; }