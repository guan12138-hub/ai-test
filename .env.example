# =====================================
# Railway 部署环境变量配置指南
# =====================================
# 后端环境变量 (backend) - 在 Railway Dashboard 中设置

# Railway 会自动注入 PORT
# MySQL 数据库连接 (建议使用 Railway MySQL 插件)
MYSQL_URL=jdbc:mysql://<host>:<port>/ai_ingredient?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&createDatabaseIfNotExist=true
MYSQL_USER=root
MYSQL_PASSWORD=your_password

# JWT 配置
JWT_SECRET=your-secure-jwt-secret-key-here
JWT_EXPIRATION=86400000

# Coze AI 接口配置
COZE_API_KEY=your_coze_api_key
COZE_API_URL=https://api.coze.cn/v1
COZE_BOT_ID=your_coze_bot_id

# 上传路径
UPLOAD_PATH=./uploads

# =====================================
# 前端环境变量 (web-frontend) - 在 Railway Dashboard 中设置
# =====================================
# 后端 API 地址 (部署后替换为 Railway 后端服务的域名)
VITE_API_BASE_URL=/api
